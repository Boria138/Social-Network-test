# Server Configuration
# For production, use port 80 (HTTP) or 443 (HTTPS)
# For development, you can use 3000
PORT=3000

# Environment
NODE_ENV=development

# SSL Certificates (for HTTPS)
# Specify paths to SSL certificates if you want to use HTTPS
# SSL_CERT=/path/to/certificate.crt
# SSL_KEY=/path/to/private.key

# Whisper CPP (Speech-to-Text) - optimized for low-resource VPS
# tiny-q8_0: ~40MB RAM, fast inference
# tiny: ~75MB RAM, better accuracy
# base: ~145MB RAM, good accuracy (requires more RAM)
WHISPER_CPP_PATH=/usr/local/bin/whisper-cli
WHISPER_CPP_MODEL=/usr/local/share/whisper.cpp/ggml-tiny-q8_0.bin
# Additional whisper-cpp arguments for low-resource systems
WHISPER_CPP_ARGS=--no-timestamps --language auto --threads 1
# FFmpeg audio filter for transcription (loudnorm for normalization)
FFMPEG_AUDIO_FILTER=loudnorm
